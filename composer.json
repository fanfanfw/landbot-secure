{
    "name": "fanfanfw/landbot-secure",
    "description": "Secure Landbot embed for Laravel with session-bound config proxying",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "landbot",
        "chatbot",
        "security",
        "embed"
    ],
    "authors": [
        {
            "name": "fanfanfw",
            "homepage": "https://github.com/fanfanfw"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fanfanfw\\LandbotSecure\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fanfanfw\\LandbotSecure\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fanfanfw\\LandbotSecure\\LandbotServiceProvider"
            ],
            "aliases": {
                "Landbot": "Fanfanfw\\LandbotSecure\\Facades\\Landbot"
            }
        }
    },
    "scripts": {
        "test": "@php ./vendor/bin/phpunit --testdox"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
